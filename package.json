{
  "name": "@ntnyq/prettier-config",
  "type": "module",
  "version": "3.1.0",
  "packageManager": "pnpm@11.9.0",
  "description": "Sharable prettier config of ntnyq.",
  "keywords": [
    "prettier",
    "prettier-config"
  ],
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "homepage": "https://github.com/ntnyq/prettier-config#readme",
  "repository": "ntnyq/prettier-config",
  "bugs": {
    "url": "https://github.com/ntnyq/prettier-config/issues"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "release": "run-s release:check release:version",
    "release:check": "run-s lint typecheck test",
    "release:version": "bumpp",
    "test": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "peerDependencies": {
    "prettier": "^3.9.0"
  },
  "devDependencies": {
    "@ntnyq/eslint-config": "^7.0.0-beta.8",
    "@ntnyq/prettier-config": "workspace:*",
    "@typescript/native-preview": "^7.0.0-dev.20260627.2",
    "bumpp": "^11.1.0",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.0",
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9"
  },
  "nano-staged": {
    "*.{js,ts,mjs,cjs,md,yml,yaml,toml,json}": "eslint --fix"
  }
}
